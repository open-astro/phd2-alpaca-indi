#!/usr/bin/make -f
# See debhelper(7) (uncomment to enable)
# output every command that modifies files on the build system.
#DH_VERBOSE = 1

# see EXAMPLES in dpkg-buildflags(1) and read /usr/share/dpkg/*
DPKG_EXPORT_BUILDFLAGS = 1
include /usr/share/dpkg/default.mk


# main packaging script based on dh7 syntax
%:
	dh $@

# INDI 2.0+ is required. Auto-detect: use system libindi if it's >= 2.0.0,
# otherwise fall back to building INDI 2.2.1.1 from source (via the
# ExternalProject in thirdparty/thirdparty.cmake). Mirrors run_deb.sh so the
# packaged build and the local build pick the same path on a given host.
USE_SYSTEM_LIBINDI := $(shell pkg-config --atleast-version=2.0.0 libindi >/dev/null 2>&1 && echo 1 || echo 0)

override_dh_auto_configure:
	@set -e; \
	VERSION="$$(grep -E '^[[:space:]]*[0-9]+\.[0-9]+\.[0-9]+([A-Za-z0-9._-]*)[[:space:]]*$$' $(CURDIR)/version.md | head -1 | sed -E 's/^[[:space:]]*//; s/[[:space:]]*$$//')"; \
	if [ -z "$$VERSION" ]; then \
		echo "ERROR: Could not read version from version.md"; \
		exit 1; \
	fi; \
	CHANGELOG_VERSION="$$(dpkg-parsechangelog -S Version | sed -E 's/-[^-]+$$//')"; \
	if [ "$$CHANGELOG_VERSION" != "$$VERSION" ]; then \
		echo "Syncing debian/changelog version $$CHANGELOG_VERSION -> $$VERSION"; \
		sed -i -E "1 s/^openastro-phd2 \\([^)]*\\) /openastro-phd2 ($$VERSION) /" $(CURDIR)/debian/changelog; \
	fi
	@if [ "$(USE_SYSTEM_LIBINDI)" = "1" ]; then \
		echo "debian/rules: USE_SYSTEM_LIBINDI=1 (system libindi >= 2.0.0)"; \
	else \
		echo "debian/rules: USE_SYSTEM_LIBINDI=0 (fetching INDI 2.2.1.1 from source)"; \
	fi
	dh_auto_configure -- -DUSE_SYSTEM_LIBINDI=$(USE_SYSTEM_LIBINDI) -DUSE_SYSTEM_GTEST=1 -DOPENSOURCE_ONLY=1

# Force ctest to run even when DEB_BUILD_OPTIONS=nocheck is set. The fork
# does not ship through Debian autobuilders, so honouring the standard
# nocheck escape hatch isn't useful here — we'd rather catch a failing
# test than ship a broken .deb. To skip the suite entirely, reconfigure
# the cmake project with -DPHD_BUILD_TESTS=OFF.
#
# We invoke ctest directly instead of dh_auto_test because dh_auto_test
# itself respects nocheck and short-circuits before running anything.
#
# Build-dir resolution is deterministic-first: try the canonical
# obj-$(DEB_HOST_GNU_TYPE) (what dh_auto_configure creates by default), and
# only fall back to a sorted glob if that's missing. The glob is sorted so
# multiple obj-*-linux-* dirs (e.g. residue from a prior cross-build) pick
# the same one across runs instead of relying on filesystem ordering.
override_dh_auto_test:
	@build_dir="obj-$(DEB_HOST_GNU_TYPE)"; \
	if [ ! -d "$$build_dir" ]; then \
		build_dir=$$(find . -maxdepth 1 -type d -name 'obj-*-linux-*' | sort | head -1); \
	fi; \
	if [ -z "$$build_dir" ] || [ ! -f "$$build_dir/CTestTestfile.cmake" ]; then \
		echo "ERROR: cmake build dir with CTestTestfile.cmake not found (tried obj-$(DEB_HOST_GNU_TYPE) and obj-*-linux-* glob)" >&2; \
		exit 1; \
	fi; \
	echo "Running ctest in $$build_dir"; \
	cd "$$build_dir" && ctest --output-on-failure

override_dh_auto_install:
	dh_auto_install
	# Rename the wrapper and binary from 'phd2' to 'openastro-phd2'
	# The wrapper script (phd2) uses exec "$0.bin" so both must match.
	if [ -f $(CURDIR)/debian/openastro-phd2/usr/bin/phd2 ]; then \
		mv $(CURDIR)/debian/openastro-phd2/usr/bin/phd2 \
		   $(CURDIR)/debian/openastro-phd2/usr/bin/openastro-phd2; \
	fi
	if [ -f $(CURDIR)/debian/openastro-phd2/usr/bin/phd2.bin ]; then \
		mv $(CURDIR)/debian/openastro-phd2/usr/bin/phd2.bin \
		   $(CURDIR)/debian/openastro-phd2/usr/bin/openastro-phd2.bin; \
	fi
	# Bundle INDI 2.x runtime libs (built from source in the Docker image;
	# Debian trixie only ships 1.9.9 which is too old).
	if ls /usr/local/lib/libindi*.so* >/dev/null 2>&1; then \
		mkdir -p $(CURDIR)/debian/openastro-phd2/usr/lib/openastro-phd2; \
		find /usr/local/lib -name 'libindi*.so*' ! -type d \
			-exec cp -P {} $(CURDIR)/debian/openastro-phd2/usr/lib/openastro-phd2/ \;; \
	fi

# Tell dh_shlibdeps where to find bundled libraries (INDI 2.x + any future
# proprietary camera libs when OPENSOURCE_ONLY=0).
# --ignore-missing-info suppresses errors for libs not owned by any .deb package.
override_dh_shlibdeps:
	dh_shlibdeps -l$(CURDIR)/debian/openastro-phd2/usr/lib/openastro-phd2 \
		--dpkg-shlibdeps-params=--ignore-missing-info

# dwz can fail on large C++ binaries — skip it
override_dh_dwz:
