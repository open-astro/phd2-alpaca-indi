#!/usr/bin/make -f
# See debhelper(7) (uncomment to enable)
# output every command that modifies files on the build system.
#DH_VERBOSE = 1

# see EXAMPLES in dpkg-buildflags(1) and read /usr/share/dpkg/*
DPKG_EXPORT_BUILDFLAGS = 1
include /usr/share/dpkg/default.mk


# main packaging script based on dh7 syntax
%:
	dh $@

# Require INDI 2.0+ by default. The Player One driver and several other
# INDI drivers have meaningful fixes after 1.9.x; building against 1.9 is
# possible but unsupported.
#
# On Debian/RPi stock repos that only ship INDI 1.9.x, add the indi PPA:
#   sudo apt-add-repository ppa:mutlaqja/ppa
# Or to build against the older system INDI anyway, set PHD2_ALLOW_INDI_1_9=1.
PHD2_ALLOW_INDI_1_9 ?= 0

override_dh_auto_configure:
	@set -e; \
	VERSION="$$(grep -E '^[[:space:]]*[0-9]+\.[0-9]+\.[0-9]+([A-Za-z0-9._-]*)[[:space:]]*$$' $(CURDIR)/version.md | head -1 | sed -E 's/^[[:space:]]*//; s/[[:space:]]*$$//')"; \
	if [ -z "$$VERSION" ]; then \
		echo "ERROR: Could not read version from version.md"; \
		exit 1; \
	fi; \
	CHANGELOG_VERSION="$$(dpkg-parsechangelog -S Version | sed -E 's/-[^-]+$$//')"; \
	if [ "$$CHANGELOG_VERSION" != "$$VERSION" ]; then \
		echo "Syncing debian/changelog version $$CHANGELOG_VERSION -> $$VERSION"; \
		sed -i -E "1 s/^phd2-alpaca \\([^)]*\\) /phd2-alpaca ($$VERSION) /" $(CURDIR)/debian/changelog; \
	fi
	dh_auto_configure -- -DUSE_SYSTEM_LIBINDI=1 -DUSE_SYSTEM_GTEST=1 -DUSE_SYSTEM_LIBUSB=1 -DOPENSOURCE_ONLY=1 $(if $(filter-out 0,$(PHD2_ALLOW_INDI_1_9)),-DPHD2_ALLOW_INDI_1_9=1,)

override_dh_auto_install:
	dh_auto_install
	# Rename the wrapper and binary from 'phd2' to 'phd2-alpaca'
	# The wrapper script (phd2) uses exec "$0.bin" so both must match.
	if [ -f $(CURDIR)/debian/phd2-alpaca/usr/bin/phd2 ]; then \
		mv $(CURDIR)/debian/phd2-alpaca/usr/bin/phd2 \
		   $(CURDIR)/debian/phd2-alpaca/usr/bin/phd2-alpaca; \
	fi
	if [ -f $(CURDIR)/debian/phd2-alpaca/usr/bin/phd2.bin ]; then \
		mv $(CURDIR)/debian/phd2-alpaca/usr/bin/phd2.bin \
		   $(CURDIR)/debian/phd2-alpaca/usr/bin/phd2-alpaca.bin; \
	fi
	# Bundle INDI 2.x runtime libs (built from source in the Docker image;
	# Debian trixie only ships 1.9.9 which is too old).
	# Skip if INDI libs aren't present (e.g. when building against system INDI 1.9.x).
	if ls /usr/local/lib/libindi*.so* >/dev/null 2>&1; then \
		mkdir -p $(CURDIR)/debian/phd2-alpaca/usr/lib/phd2-alpaca; \
		find /usr/local/lib -name 'libindi*.so*' ! -type d \
			-exec cp -P {} $(CURDIR)/debian/phd2-alpaca/usr/lib/phd2-alpaca/ \;; \
	fi

# Tell dh_shlibdeps where to find bundled libraries (INDI 2.x + any future
# proprietary camera libs when OPENSOURCE_ONLY=0).
# --ignore-missing-info suppresses errors for libs not owned by any .deb package.
override_dh_shlibdeps:
	dh_shlibdeps -l$(CURDIR)/debian/phd2-alpaca/usr/lib/phd2-alpaca \
		--dpkg-shlibdeps-params=--ignore-missing-info

# dwz can fail on large C++ binaries — skip it
override_dh_dwz:
