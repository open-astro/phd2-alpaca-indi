#!/bin/bash
set -e

case "$1" in
    purge)
        # Remove the system user created during install
        if getent passwd phd2-alpaca > /dev/null 2>&1; then
            deluser --system phd2-alpaca || true
        fi
        if getent group phd2-alpaca > /dev/null 2>&1; then
            delgroup --system phd2-alpaca || true
        fi
        ;;
esac

#DEBHELPER#
