[Unit]
Description=PHD2 Alpaca Headless Guiding Server
Documentation=https://github.com/open-astro/phd2-alpaca
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=phd2-alpaca
Group=phd2-alpaca
WorkingDirectory=/var/lib/phd2-alpaca
Environment=LD_LIBRARY_PATH=/usr/lib/phd2-alpaca
ExecStart=/usr/bin/xvfb-run -a /usr/bin/phd2-alpaca --headless --headless-auto-connect
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
